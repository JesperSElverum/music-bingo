{
  "name": "music-bingo",
  "private": true,
  "version": "0.1.0",
  "description": "Spotify-powered party music bingo",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev -w server\" \"npm:dev -w client\"",
    "build": "npm run build -w client",
    "start": "node server/src/index.js",
    "typecheck": "npm run typecheck -w client"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
